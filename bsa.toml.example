# Copy this file to bsa.toml and fill in your API keys.
# Precedence: BSA_* / OPENAI_* / ISBNDB_* environment variables > bsa.toml > built-in defaults.

# --- Secrets (env vars override these) ---
# openai_api_key = "sk-..."
# isbndb_api_key = "..."

# --- Source cascade toggles ---
isbndb_lookup_enabled = true
national_agency_routing_enabled = true
bne_lookup_enabled = true
llm_enrichment_enabled = true
llm_record_validation_enabled = true

# --- Source endpoints / tuning ---
bne_sru_base_url = "https://catalogo.bne.es/view/sru/34BNE_INST"
source_request_pause_seconds = 0.5
request_timeout_seconds = 10.0
open_library_batch_size = 25
google_books_max_retries = 2
google_books_backoff_seconds = 1.0

# --- LLM thresholds ---
llm_enrichment_timeout_seconds = 60.0
llm_record_validation_min_confidence = 0.80
